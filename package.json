{
  "name": "api-openapi",
  "private": true,
  "version": "1.0.0",
  "description": "Standalone OpenAPI spec for the Nexus public v3 commerce API",
  "scripts": {
    "lint": "redocly lint specs/v3/openapi.yaml",
    "build": "node ./scripts/build-json.mjs",
    "build:docs": "redocly build-docs specs/v3/openapi.yaml --output dist/index.html",
    "build:site": "node ./scripts/build-site.mjs"
  },
  "devDependencies": {
    "@redocly/cli": "^2.25.1",
    "yaml": "^2.8.3"
  }
}
